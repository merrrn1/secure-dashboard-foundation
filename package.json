{
  "name": "secure-dashboard-foundation",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace @secure-dashboard/api",
    "dev:web": "npm run dev --workspace @secure-dashboard/web",
    "test": "npm run test --workspace @secure-dashboard/api",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "build": "npm run build --workspaces --if-present"
  },
  "devDependencies": {
    "typescript": "6.0.3"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.19"
    }
  },
  "engines": {
    "node": ">=22"
  }
}
